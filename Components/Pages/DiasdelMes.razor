@page "/diasdel-mes"

<h3>Conocer los días del mes</h3>

<div class="mb-3">
    <label>Mes (1-12):</label>
    <input type="number" @bind="mes" class="form-control" />
</div>

<div class="mb-3">
    <label>Año:</label>
    <input type="number" @bind="anio" class="form-control" />
</div>

<button class="btn btn-primary" @onclick="CalcularDias">
    Mostrar número de días
</button>

@if (!string.IsNullOrEmpty(resultado))
{
    <div class="alert alert-info mt-3">
        @resultado
    </div>
}

@code {
    int mes;
    int anio;
    string resultado = "";

    void CalcularDias()
    {
        if (mes < 1 || mes > 12 || anio <= 0)
        {
            resultado = "Por favor ingresa valores válidos.";
            return;
        }

        int dias = 0;

        // Meses con 31 días
        if (mes == 1 || mes == 3 || mes == 5 || mes == 7 ||
            mes == 8 || mes == 10 || mes == 12)
        {
            dias = 31;
        }
        // Meses con 30 días
        else if (mes == 4 || mes == 6 || mes == 9 || mes == 11)
        {
            dias = 30;
        }
        // Febrero
        else if (mes == 2)
        {
            if (EsBisiesto(anio))
                dias = 29;
            else
                dias = 28;
        }

        resultado = $"El mes {mes} del año {anio} tiene {dias} días.";
    }

    bool EsBisiesto(int año)
    {
        return (año % 4 == 0 && año % 100 != 0) || (año % 400 == 0);
    }
}
