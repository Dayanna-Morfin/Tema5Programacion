@page "/numerosprimos"

<h3>NumerosPrimos</h3>
<div>
    <label>Número entero</label>
    <input type="number" @bind="numero" />
</div>

<br />

<button class="btn btn-primary" @onclick="GenerarPrimos">
    Generar primos
</button>

<br /><br />

<h4>Números primos</h4>

@foreach (var n in primos)
{
    <div class="p-2 mb-2 bg-light">@n</div>
}

@code {
    int numero;
    List<int> primos = new List<int>();

    void GenerarPrimos()
    {
    primos.Clear();

    for(int i=2;i <= numero;i++)
    {
    if(EsPrimo(i))
    {
    primos.Add(i);
    }
        }
    }

    bool EsPrimo(int n)
{
    if (n <= 1) return false;
    for(int i=2; i <= n/2; i++)
    {
    if (n % i == 0)
        return false;
    }
    return true;
}
}
